# ha-notify-proxy: static Go binary into distroless nonroot — no shell, no
# package manager. Single-purpose capability narrower for Home Assistant notify
# (ADR-0006). Build: docker build -f Dockerfile.ha-notify-proxy .
FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /out/ha-notify-proxy ./cmd/ha-notify-proxy

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/ha-notify-proxy /ha-notify-proxy
# 8444 = TLS API listener (agents); 8082 = health/metrics (scrapers only).
EXPOSE 8444 8082
USER nonroot:nonroot
ENTRYPOINT ["/ha-notify-proxy"]
